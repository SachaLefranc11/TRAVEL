generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String
  password     String
  avatar       String?
  createdAt    DateTime          @default(now())
  trips        TripParticipant[]
  expenses     Expense[]
  resetTokens  PasswordResetToken[]
}

// Jetons de réinitialisation de mot de passe.
// On stocke un HASH du jeton (jamais le jeton en clair) ; le jeton brut n'existe
// que dans l'email envoyé à l'utilisateur. Expiration courte + usage unique.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trip {
  id           String            @id @default(cuid())
  title        String
  destination  String
  coverImage   String?
  startDate    DateTime
  endDate      DateTime
  description  String?
  createdAt    DateTime          @default(now())
  ownerId      String
  participants TripParticipant[]
  expenses     Expense[]
  locations    Location[]
}

model TripParticipant {
  id     String @id @default(cuid())
  userId String
  tripId String
  role   String @default("MEMBER")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  currency  String   @default("EUR")
  category  String
  date      DateTime
  notes     String?
  paidById  String
  tripId    String
  paidBy    User     @relation(fields: [paidById], references: [id])
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Cache des suggestions IA par destination (évite de rappeler Groq)
model ActivityCache {
  id          String   @id @default(cuid())
  destination String   @unique
  activities  String   // JSON stringifié
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Location {
  id          String  @id @default(cuid())
  tripId      String
  name        String
  type        String
  lat         Float
  lng         Float
  description String?
  address     String?
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
