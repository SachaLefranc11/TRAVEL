generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String
  password     String
  avatar       String?
  createdAt    DateTime          @default(now())
  trips        TripParticipant[]
  expenses     Expense[]
  shares       ExpenseShare[]
  resetTokens  PasswordResetToken[]
  plannerActivities PlannerActivity[]
  settlementsFrom Settlement[] @relation("SettlementFrom")
  settlementsTo   Settlement[] @relation("SettlementTo")
  plannerLogs     PlannerActivityLog[]
  notifications   Notification[]
}

// Notification in-app destinée à un utilisateur.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // EXPENSE | PLANNER | INVITE
  message   String
  tripId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Jetons de réinitialisation de mot de passe.
// On stocke un HASH du jeton (jamais le jeton en clair) ; le jeton brut n'existe
// que dans l'email envoyé à l'utilisateur. Expiration courte + usage unique.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trip {
  id           String            @id @default(cuid())
  title        String
  destination  String
  coverImage   String?
  startDate    DateTime
  endDate      DateTime
  description  String?
  createdAt    DateTime          @default(now())
  ownerId      String
  participants TripParticipant[]
  expenses     Expense[]
  locations    Location[]
  plannerActivities PlannerActivity[]
  settlements  Settlement[]
  plannerLogs  PlannerActivityLog[]
}

// Journal des modifications du planning (qui, quoi avant/après, quand).
model PlannerActivityLog {
  id            String   @id @default(cuid())
  tripId        String
  activityId    String?
  action        String   // CREATE | UPDATE | DELETE
  userId        String
  activityTitle String
  before        String?  // snapshot JSON avant (UPDATE/DELETE)
  after         String?  // snapshot JSON après (CREATE/UPDATE)
  createdAt     DateTime @default(now())
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([tripId])
}

// Remboursement enregistré entre deux participants (règle une dette).
model Settlement {
  id         String   @id @default(cuid())
  tripId     String
  fromUserId String
  toUserId   String
  amount     Float
  currency   String   @default("EUR")
  createdAt  DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([tripId])
}

// Activité planifiée jour par jour (planning collaboratif).
// `date` = jour (minuit UTC) ; `startTime`/`endTime` = "HH:MM" pour éviter les soucis de fuseau.
model PlannerActivity {
  id          String   @id @default(cuid())
  tripId      String
  date        DateTime
  title       String
  description String?
  startTime   String?
  endTime     String?
  location    String?
  createdById String
  createdAt   DateTime @default(now())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([tripId])
}

model TripParticipant {
  id     String @id @default(cuid())
  userId String
  tripId String
  role   String @default("MEMBER")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  currency  String   @default("EUR")
  category  String
  date      DateTime
  notes     String?
  paidById  String
  tripId    String
  paidBy    User     @relation(fields: [paidById], references: [id])
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  shares    ExpenseShare[]
  createdAt DateTime @default(now())

  // Dépense personnelle générée automatiquement à partir d'une dépense partagée
  // (la part de chaque participant). parentExpenseId pointe vers la dépense de groupe.
  parentExpenseId String?
  parent          Expense?  @relation("ExpenseSplit", fields: [parentExpenseId], references: [id], onDelete: Cascade)
  children        Expense[] @relation("ExpenseSplit")

  @@index([parentExpenseId])
}

// Part d'une dépense due par un participant (modèle façon Tricount).
// Pour une dépense "perso", il y a une seule part = le payeur lui-même.
// Pour une dépense de groupe, une part par participant concerné.
model ExpenseShare {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Float
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
}

// Cache des suggestions IA par destination (évite de rappeler Groq)
model ActivityCache {
  id          String   @id @default(cuid())
  destination String   @unique
  activities  String   // JSON stringifié
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Location {
  id          String  @id @default(cuid())
  tripId      String
  name        String
  type        String
  lat         Float
  lng         Float
  description String?
  address     String?
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
